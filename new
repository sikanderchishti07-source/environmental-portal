<script>
(function(){
  // Scrolled state
  var nav = document.getElementById('navbar');
  window.addEventListener('scroll', function(){
    nav.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Logo click
  document.getElementById('navLogoBtn').addEventListener('click', function(){
    var p = window.location.pathname;
    var home = p === '/' || p === '' || /index(__|\.html?)?$/i.test(p) || p.endsWith('/');
    if (home) window.scrollTo({ top: 0, behavior: 'smooth' });
    else window.location.href = '/';
  });

  // Drawer
  window.toggleNavDrawer = function(){
    var drawer = document.getElementById('navMobileDrawer');
    var overlay = document.getElementById('navDrawerOverlay');
    var ham = document.getElementById('navHamburger');
    var isOpen = drawer.classList.contains('open');
    drawer.classList.toggle('open');
    overlay.classList.toggle('open');
    ham.classList.toggle('open');
    document.body.style.overflow = isOpen ? '' : 'hidden';
  };
  window.closeNavDrawer = function(){
    document.getElementById('navMobileDrawer').classList.remove('open');
    document.getElementById('navDrawerOverlay').classList.remove('open');
    document.getElementById('navHamburger').classList.remove('open');
    document.body.style.overflow = '';
  };

  // Close drawer on anchor links
  document.querySelectorAll('#navMobileDrawer a[href^="#"]').forEach(function(a){
    a.addEventListener('click', function(){ closeNavDrawer(); });
  });
})();
</script>


